# Panel server (panel.1clkaccess.store) — API + dashboard only
# Copy to server/.env on the VPS

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=NewHttpGoAuto
DB_PASS=YOUR_MYSQL_PASSWORD
DB_NAME=newhttpgoauto

PORT=4010
ENV=production
ROLE=panel
ENABLE_SCHEDULER=true

JWT_SECRET=CHANGE_TO_LONG_RANDOM_STRING
MASTER_USERNAME=admin
MASTER_PASSWORD=CHANGE_MASTER_PASSWORD
API_KEY=CHANGE_API_KEY_FOR_EXTERNAL_TRIGGERS
LOG_RETENTION_DAYS=2
