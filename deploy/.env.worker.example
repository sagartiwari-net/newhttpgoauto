# Automation worker Mac — runs scheduled tasks + manual runs
# Copy to server/.env on your Mac

# Direct (if port 3306 open) or use SSH tunnel: DB_HOST=127.0.0.1 DB_PORT=3307
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=NewHttpGoAuto
DB_PASS=YOUR_MYSQL_PASSWORD
DB_NAME=newhttpgoauto

PORT=4011
ENV=development
ROLE=worker
ENABLE_SCHEDULER=true
WORKER_ID=mac-worker

JWT_SECRET=SAME_AS_PANEL_SERVER
MASTER_USERNAME=admin
MASTER_PASSWORD=SAME_AS_PANEL
API_KEY=SAME_AS_PANEL
LOG_RETENTION_DAYS=2
