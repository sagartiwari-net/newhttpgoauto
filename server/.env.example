# GoHttpAuto Server Configuration
# Local dev with SSH tunnel: DB_HOST=127.0.0.1 DB_PORT=3307

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=NewHttpGoAuto
DB_PASS=your_mysql_password
DB_NAME=newhttpgoauto

PORT=4010
ENV=development
ENABLE_SCHEDULER=true

JWT_SECRET=change_this_to_a_long_random_secret_key
MASTER_USERNAME=admin
MASTER_PASSWORD=change_master_password
API_KEY=gohttp_secret_token_change_me
LOG_RETENTION_DAYS=2
